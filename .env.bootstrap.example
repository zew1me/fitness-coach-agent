# Bootstrap credentials — copy to .env.bootstrap and fill in.
# Run: cp .env.bootstrap.example .env.bootstrap
# Never commit .env.bootstrap.

# --- Supabase Management API ---
# Only required when auto-creating Supabase projects. Existing projects use your
# local Supabase CLI login (`supabase login`) for verification and API keys.
SUPABASE_ACCESS_TOKEN=

# Org slug from your Supabase dashboard URL, e.g. "my-org" in
# https://supabase.com/dashboard/org/my-org/general
SUPABASE_ORG_ID=

# If your Supabase projects already exist, provide their refs to skip creation.
# Leave blank to auto-create projects named fitness-coach-agent-{env}.
# Find the ref at: supabase.com/dashboard/project/{ref}/settings/general
SUPABASE_PROJECT_REF_PREVIEW=
SUPABASE_PROJECT_REF_PROD=

# Required for automated migrations when using existing projects. If a bootstrap
# run created the project, this is captured in scripts/bootstrap/.state.{env}.json.
SUPABASE_DB_PASSWORD_PREVIEW=
SUPABASE_DB_PASSWORD_PROD=

# Optional fallback for existing projects when `supabase projects api-keys` cannot
# read keys. Get these from Project Settings → API in the Supabase dashboard.
SUPABASE_URL_PREVIEW=
SUPABASE_ANON_KEY_PREVIEW=
SUPABASE_SERVICE_ROLE_KEY_PREVIEW=
SUPABASE_URL_PROD=
SUPABASE_ANON_KEY_PROD=
SUPABASE_SERVICE_ROLE_KEY_PROD=

# --- Cloudflare (R2) ---
# Create a token at: dash.cloudflare.com → My Profile → API Tokens
# Required permission: R2 bucket edit, so bootstrap can create or verify buckets.
CF_API_TOKEN=

# Visible in the right sidebar on any Cloudflare dashboard page
CF_ACCOUNT_ID=

# Runtime R2 S3 credentials used by the backend. Create these after the bucket
# exists: Cloudflare dashboard → R2 → Manage API tokens → account-level token
# scoped to the bucket with Object Read & Write.
R2_ACCESS_KEY_ID_PREVIEW=
R2_SECRET_ACCESS_KEY_PREVIEW=
R2_ACCESS_KEY_ID_PROD=
R2_SECRET_ACCESS_KEY_PROD=

# Optional: override the R2 public base URL per environment.
# Bootstrap auto-detects these from the Cloudflare API (requires "Public Access"
# enabled on the bucket). Set manually if auto-detection fails or you're using
# a custom domain on your R2 bucket (e.g. "https://assets.example.com").
# Preview and production buckets have different URLs, so configure separately.
R2_PUBLIC_BASE_URL_PREVIEW=
R2_PUBLIC_BASE_URL_PROD=

# --- Vercel ---
# Authentication uses the local `vercel` CLI (run `vercel login` first).
# No token is needed; the bootstrap script invokes `vercel api` for env writes.

# Optional: set a custom production domain (e.g. "app.example.com").
# If blank, the script will auto-read the canonical domain from your Vercel project.
PRODUCTION_DOMAIN=

# --- Custom SMTP (Resend) for auth emails ---
# Applied identically to BOTH preview and production so magic-link / OTP email
# delivery is at parity. Leave SMTP_PASS and SMTP_ADMIN_EMAIL blank to keep
# Supabase's built-in (rate-limited) sender — not suitable for production.
#
# SMTP_PASS is your Resend API key (create at resend.com → API Keys). The Resend
# SMTP username is the literal string "resend". SMTP_ADMIN_EMAIL must be an
# address on a domain you've verified in Resend (e.g. "login@yourdomain.com").
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
SMTP_ADMIN_EMAIL=
SMTP_SENDER_NAME=

# --- Application secrets ---
# These get written into Vercel environment variables for both envs.
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...

# --- Sentry (optional) ---
# Two distinct DSNs (separate Sentry Client Keys), so the public browser key can
# never expose the server one. Create both at:
#   Sentry → Settings → Projects → javascript-nextjs → Client Keys (DSN).
# Server/edge/python DSN → Vercel SENTRY_DSN (stored sensitive/write-only).
SENTRY_DSN=
# Browser DSN → Vercel NEXT_PUBLIC_SENTRY_DSN (public, inlined into the client bundle).
SENTRY_PUBLIC_DSN=
# Build-time secret used by withSentryConfig to upload source maps for readable
# stack traces. Create at: Sentry → Settings → Auth Tokens (scope: project:releases).
# Stored as a sensitive (write-only) Vercel env var. Leave blank to skip uploads.
SENTRY_AUTH_TOKEN=
