# Bootstrap credentials — copy to .env.bootstrap and fill in.
# Run: cp .env.bootstrap.example .env.bootstrap
# Never commit .env.bootstrap.

# --- Supabase Management API ---
# Get at: supabase.com → Account → Access Tokens
SUPABASE_ACCESS_TOKEN=sbp_...

# Org slug from your Supabase dashboard URL, e.g. "my-org" in
# https://supabase.com/dashboard/org/my-org/general
SUPABASE_ORG_ID=

# If your Supabase projects already exist, provide their refs to skip creation.
# Leave blank to auto-create projects named fitness-coach-agent-{env}.
# Find the ref at: supabase.com/dashboard/project/{ref}/settings/general
SUPABASE_PROJECT_REF_PREVIEW=
SUPABASE_PROJECT_REF_PROD=

# --- Cloudflare (R2) ---
# Create a token at: dash.cloudflare.com → My Profile → API Tokens
# Required permission: "Cloudflare R2 Storage: Edit"
CF_API_TOKEN=

# Visible in the right sidebar on any Cloudflare dashboard page
CF_ACCOUNT_ID=

# --- Vercel ---
# Get at: vercel.com/account/tokens
VERCEL_TOKEN=

# Optional: set a custom production domain (e.g. "app.example.com").
# If blank, the script will auto-read the canonical domain from your Vercel project.
PRODUCTION_DOMAIN=

# --- Application secrets ---
# These get written into Vercel environment variables for both envs.
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...
