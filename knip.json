{
  "$schema": "https://unpkg.com/knip/schema.json",
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": [
    "@next/eslint-plugin-next",
    "@testing-library/jest-dom",
    "eslint-config-next",
    "jscpd"
  ],
  "ignore": [
    ".worktrees/**",
    ".codex/**",
    ".agents/**",
    ".claude/**",
    ".serena/**",
    ".remember/**",
    ".cache/**",
    ".dev/**",
    ".uv-cache/**",
    ".venv/**",
    ".vercel/**",
    ".next/**"
  ],
  "ignoreBinaries": ["uv"],
  "lefthook": false
}
