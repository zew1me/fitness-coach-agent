{
  "name": "exercise-training-plan-gpt",
  "private": true,
  "packageManager": "bun@1.2.4",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "prepare": "lefthook install --force",
    "dev": "next dev",
    "dev:local": "bash scripts/dev-local.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "check": "bun run lint && bun run typecheck && bun run test",
    "test:oai": "vitest run --config vitest.oai.config.ts",
    "test:ui": "playwright test",
    "format": "prettier --write .",
    "db:start": "bash scripts/db-start.sh",
    "db:stop": "bash scripts/db-stop.sh",
    "db:reset": "bash scripts/db-reset.sh",
    "setup:preview": "uv run python -m scripts.bootstrap.main --env preview",
    "setup:prod": "uv run python -m scripts.bootstrap.main --env prod"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.170",
    "@openai/agents": "^0.11.8",
    "@sentry/nextjs": "^10",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.49.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.168",
    "next": "^15.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.22.0",
    "@next/eslint-plugin-next": "^15.2.2",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.2",
    "eslint-import-resolver-typescript": "^4.3.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^16.0.0",
    "jscpd": "^5.0.5",
    "jsdom": "^26.1.0",
    "knip": "^6.16.1",
    "lefthook": "^2.1.9",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
