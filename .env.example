APP_ENV=development
APP_BASE_URL=http://localhost:3000
APP_JWT_SECRET=replace-me
INTERVALS_CLIENT_ID=
INTERVALS_CLIENT_SECRET=
INTERVALS_TOKEN_ENCRYPTION_SECRET=
INVITE_CODE=
# Sentry browser key (optional locally). Public, inlined into the client bundle.
# Distinct from the server-side SENTRY_DSN below. Leave blank to disable in local dev.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
OPENAI_API_KEY=
OPENAI_LEAD_MODEL=gpt-5.5
OPENAI_LEAD_REASONING_EFFORT=medium
OPENAI_SPECIALIST_MODEL=gpt-5.4-mini
OPENAI_SPECIALIST_REASONING_EFFORT=low
OPENAI_SPECIALIST_TEXT_VERBOSITY=low
OPENAI_TEXT_VERBOSITY=low
OPENAI_ACTIVITY_TEXT_MODEL=gpt-5.5
OPENAI_ACTIVITY_TEXT_TIMEOUT_SECONDS=60
OPENAI_VISION_MODEL=gpt-5.4-mini
OPENAI_VISION_TIMEOUT_SECONDS=45
OPENAI_VISION_MAX_OUTPUT_TOKENS=8000
OPENAI_VISION_REASONING_EFFORT=low
# Set both to full_history only for temporary rollback. Default is durable session mode.
COACH_CONTEXT_STRATEGY=session
NEXT_PUBLIC_COACH_CONTEXT_STRATEGY=session
TAVILY_API_KEY=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT_URL=
R2_PUBLIC_BASE_URL=
# Sentry server/edge/python key (optional locally, secret). A separate Client Key
# from NEXT_PUBLIC_SENTRY_DSN above. Leave blank to disable in local dev.
SENTRY_DSN=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
