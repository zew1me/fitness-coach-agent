APP_ENV=development
APP_BASE_URL=http://localhost:3000
APP_JWT_SECRET=replace-me
INVITE_CODE=
# Sentry browser key (optional locally). Public, inlined into the client bundle.
# Distinct from the server-side SENTRY_DSN below. Leave blank to disable in local dev.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
OPENAI_API_KEY=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT_URL=
R2_PUBLIC_BASE_URL=
# Sentry server/edge/python key (optional locally, secret). A separate Client Key
# from NEXT_PUBLIC_SENTRY_DSN above. Leave blank to disable in local dev.
SENTRY_DSN=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
TAVILY_API_KEY=
